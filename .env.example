# AutoResearch Safe Starter environment example
#
# Copy the values you need into your Docker runtime environment, Akash SDL, or
# another secret manager. Do not commit a real API key to git.

# Required secret: API key for the LLM provider your orchestration layer uses.
LLM_API_KEY=replace-with-your-real-api-key

# Required non-secret: the provider name that matches the API key above.
LLM_PROVIDER=anthropic

# Required non-secret: the model your agent or orchestration layer should call.
MODEL_NAME=claude-3-7-sonnet-20250219

# Optional runtime paths. These defaults are safe for Akash and local Docker.
DATA_DIR=/data
LOG_DIR=/data/logs
OUTPUT_DIR=/data/output

# Optional starter behavior. The current safe first pass keeps the container
# alive after preparation so you can attach orchestration later.
RUN_MODE=agent
MAX_ITERS=25
EXPERIMENT_TIMEOUT_SECONDS=900
